---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Guided Apps to discuss building a GPS-guided tour experience for your city or organization.">
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container text-center">
      <h1>Get in Touch</h1>
      <p>Interested in building a guided experience? Let's talk.</p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="section">
    <div class="container">
      <div class="contact-layout">
        <div class="contact-info reveal">
          <h2>Let's Build Something Together</h2>
          <p>
            Whether you're a tourism board looking to boost foot traffic, a pub crawl
            company going digital, or an entrepreneur with a new idea — we'd love to hear from you.
          </p>

          <div class="contact-details">
            <div class="contact-item">
              <div class="contact-icon">📧</div>
              <div>
                <h4>Email</h4>
                <a href="mailto:hello@guided-apps.com">hello@guided-apps.com</a>
              </div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">🌐</div>
              <div>
                <h4>Website</h4>
                <a href="https://guided-apps.com">guided-apps.com</a>
              </div>
            </div>
          </div>

          <div class="contact-brands">
            <h4>Our Brands</h4>
            <ul>
              <li><a href="https://exploreadora.com" target="_blank" rel="noopener">Explore a DORA</a></li>
              <li><a href="https://city-walks.com" target="_blank" rel="noopener">City Walks</a></li>
              <li><a href="https://brew-tours.com" target="_blank" rel="noopener">Brew Tours</a></li>
            </ul>
          </div>
          <div class="contact-brands">
            <h4>Experiences</h4>
            <ul>
              <li><a href="https://patriotpubcrawl.guided-apps.com" target="_blank" rel="noopener">Patriot Pub Crawl</a></li>
            </ul>
          </div>
        </div>

        <div class="contact-form-wrapper reveal reveal-delay-2">
          <form class="contact-form" id="contact-form" action="https://formspree.io/f/placeholder" method="POST">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="Your name" />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required placeholder="you@example.com" />
            </div>
            <div class="form-group">
              <label for="organization">Organization</label>
              <input type="text" id="organization" name="organization" placeholder="Your company or organization" />
            </div>
            <div class="form-group">
              <label for="interest">What are you interested in?</label>
              <select id="interest" name="interest">
                <option value="">Select one...</option>
                <option value="pub-crawl">Pub Crawl / Bar Trail</option>
                <option value="food-tour">Food Tour</option>
                <option value="walking-tour">Walking / Historical Tour</option>
                <option value="brewery-trail">Brewery Trail</option>
                <option value="team-building">Corporate / Team Building</option>
                <option value="event">Event or Festival</option>
                <option value="other">Something Else</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Tell us about your idea</label>
              <textarea id="message" name="message" rows="5" required placeholder="What city? What kind of experience? What's your audience?"></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Send Message</button>
          </form>
          <p class="form-note">We'll respond within 1-2 business days.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--color-navy) 0%, #0d2137 100%);
    color: white;
    padding: 10rem 1.5rem 4rem;
  }

  .page-hero h1 {
    color: white;
    margin-bottom: 1rem;
  }

  .page-hero p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.2rem;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Layout */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-info h2 {
    margin-bottom: 1rem;
  }

  .contact-info > p {
    color: var(--color-gray);
    margin-bottom: 2rem;
  }

  /* Contact Details */
  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .contact-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact-icon {
    font-size: 1.5rem;
    flex: 0 0 auto;
  }

  .contact-item h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray);
    margin-bottom: 0.2rem;
  }

  .contact-item a {
    font-size: 1rem;
    font-weight: 500;
  }

  /* Brands */
  .contact-brands h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray);
    margin-bottom: 0.75rem;
  }

  .contact-brands ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .contact-brands a {
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* Form */
  .contact-form {
    background: var(--color-off-white);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid var(--color-gray-light);
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.4rem;
    color: var(--color-text);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.7rem 1rem;
    border: 1px solid #d5d9dd;
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    background: white;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-blue);
    box-shadow: 0 0 0 3px rgba(36, 113, 163, 0.1);
  }

  .form-group textarea {
    resize: vertical;
  }

  .btn-full {
    width: 100%;
  }

  .form-note {
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-gray);
    margin-top: 1rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
