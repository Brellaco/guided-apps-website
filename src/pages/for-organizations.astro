---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="For Cities & Organizations" description="Partner with Guided Apps to build GPS-guided tour experiences for your city, tourism board, hospitality group, or organization.">
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container text-center">
      <h1>For Cities & Organizations</h1>
      <p>We build custom GPS-guided experiences for tourism boards, hospitality groups, cities, and entrepreneurs.</p>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="section">
    <div class="container">
      <h2 class="section-title reveal">Why Guided Apps?</h2>
      <p class="section-subtitle reveal reveal-delay-1">
        Your visitors are already walking your city with their phones out. Give them a reason to explore more — and keep coming back.
      </p>
      <div class="value-grid">
        <div class="value-card reveal reveal-delay-1">
          <h3>No App Store Friction</h3>
          <p>PWA technology means visitors open a link and start immediately — no downloads, no installs, no lost users.</p>
        </div>
        <div class="value-card reveal reveal-delay-2">
          <h3>Your Brand, Your Trail</h3>
          <p>Custom domain, colors, logo, and content. It looks and feels like your own product — because it is.</p>
        </div>
        <div class="value-card reveal reveal-delay-3">
          <h3>Turnkey Platform</h3>
          <p>We handle the technology — GPS, maps, check-ins, groups, hosting. You focus on the content and your audience.</p>
        </div>
        <div class="value-card reveal reveal-delay-1">
          <h3>Real Engagement Data</h3>
          <p>Know which stops get the most visits, how many users complete the trail, and where people spend their time.</p>
        </div>
        <div class="value-card reveal reveal-delay-2">
          <h3>Easy Content Updates</h3>
          <p>Add new stops, update descriptions, swap photos — all through a simple manager dashboard. No developer needed.</p>
        </div>
        <div class="value-card reveal reveal-delay-3">
          <h3>Group-Friendly</h3>
          <p>Perfect for team building, tours, pub crawls, and events. Groups can track each other and progress together.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="section-alt">
    <div class="container">
      <h2 class="section-title reveal">Who It's For</h2>
      <p class="section-subtitle reveal reveal-delay-1">
        The Guided Apps platform adapts to any city, theme, or audience.
      </p>
      <div class="use-cases">
        <div class="use-case reveal reveal-delay-1">
          <div class="use-case-icon">🏛️</div>
          <h3>Tourism Boards & CVBs</h3>
          <p>Drive foot traffic to local businesses with branded walking tours that showcase your city's best attractions, restaurants, and hidden gems.</p>
        </div>
        <div class="use-case reveal reveal-delay-2">
          <div class="use-case-icon">🍺</div>
          <h3>Pub Crawl & Bar Companies</h3>
          <p>Digitize your pub crawl with GPS navigation, automatic check-ins at each bar, and group tracking — no paper maps or wristbands needed.</p>
        </div>
        <div class="use-case reveal reveal-delay-3">
          <div class="use-case-icon">🍕</div>
          <h3>Food Tour Operators</h3>
          <p>Create self-guided food tours where participants navigate between restaurants with GPS, see what to order at each stop, and track their progress.</p>
        </div>
        <div class="use-case reveal reveal-delay-1">
          <div class="use-case-icon">🏰</div>
          <h3>Historical Societies</h3>
          <p>Bring history to life with GPS-guided heritage walks. Each stop tells a story with rich descriptions, photos, and contextual information.</p>
        </div>
        <div class="use-case reveal reveal-delay-2">
          <div class="use-case-icon">🏢</div>
          <h3>Corporate & Team Building</h3>
          <p>Organize team outings with built-in group features. Teams compete to visit stops, check in, and complete the trail together.</p>
        </div>
        <div class="use-case reveal reveal-delay-3">
          <div class="use-case-icon">🎉</div>
          <h3>Event Organizers</h3>
          <p>Festival routes, conference city guides, wedding weekend activities — temporary or permanent, we build experiences for any occasion.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Work -->
  <section class="section">
    <div class="container">
      <h2 class="section-title reveal">How We Work Together</h2>
      <p class="section-subtitle reveal reveal-delay-1">
        From concept to launch, we handle the build so you can focus on your audience.
      </p>
      <div class="process-steps">
        <div class="process-step reveal reveal-delay-1">
          <div class="process-number">01</div>
          <h3>Discovery</h3>
          <p>We learn about your city, your audience, and your goals. What kind of experience do you want to create?</p>
        </div>
        <div class="process-step reveal reveal-delay-2">
          <div class="process-number">02</div>
          <h3>Design & Build</h3>
          <p>We configure the platform with your branding, stops, routes, and content. You review and refine.</p>
        </div>
        <div class="process-step reveal reveal-delay-3">
          <div class="process-number">03</div>
          <h3>Launch</h3>
          <p>Your experience goes live on its own custom domain. Share the link and watch visitors start exploring.</p>
        </div>
        <div class="process-step reveal reveal-delay-4">
          <div class="process-number">04</div>
          <h3>Grow</h3>
          <p>Use the manager dashboard to update content, track analytics, and evolve the experience over time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container text-center">
      <h2 class="reveal">Let's Build Something Together</h2>
      <p class="reveal reveal-delay-1">
        Tell us about your city, your audience, and your vision. We'll show you what's possible.
      </p>
      <a href="/contact" class="btn btn-primary reveal reveal-delay-2">Start the Conversation</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--color-navy) 0%, #0d2137 100%);
    color: white;
    padding: 10rem 1.5rem 4rem;
  }

  .page-hero h1 {
    color: white;
    margin-bottom: 1rem;
  }

  .page-hero p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.2rem;
    max-width: 650px;
    margin: 0 auto;
  }

  /* Value Grid */
  .value-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .value-card {
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid var(--color-gray-light);
    transition: all 0.3s ease;
  }

  .value-card:hover {
    border-color: var(--color-orange);
    box-shadow: 0 4px 20px rgba(230, 126, 34, 0.1);
  }

  .value-card h3 {
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  .value-card p {
    color: var(--color-gray);
    font-size: 0.9rem;
  }

  /* Use Cases */
  .use-cases {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .use-case {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
  }

  .use-case:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
  }

  .use-case-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .use-case h3 {
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  .use-case p {
    color: var(--color-gray);
    font-size: 0.9rem;
  }

  /* Process */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .process-step {
    text-align: center;
    position: relative;
  }

  .process-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-orange);
    opacity: 0.3;
    margin-bottom: 0.5rem;
  }

  .process-step h3 {
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  .process-step p {
    color: var(--color-gray);
    font-size: 0.9rem;
    margin: 0 auto;
  }

  /* CTA */
  .cta-section {
    background: linear-gradient(135deg, var(--color-blue) 0%, var(--color-navy) 100%);
    color: white;
    padding: 5rem 1.5rem;
  }

  .cta-section h2 {
    color: white;
    margin-bottom: 1rem;
  }

  .cta-section p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .value-grid,
    .use-cases {
      grid-template-columns: 1fr;
    }

    .process-steps {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .process-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
